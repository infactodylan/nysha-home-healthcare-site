# Public site URL (used for absolute Open Graph / Twitter image URLs)
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional: base URL when running `npm run og:capture` (default http://127.0.0.1:3000)
# OG_CAPTURE_BASE_URL=http://127.0.0.1:3000

# SendGrid (required for contact form emails in production)
SENDGRID_API_KEY=
# Must be a verified sender in SendGrid (single email)
SENDGRID_FROM_EMAIL=
# Inbox that receives contact form submissions
QUOTE_LEAD_TO_EMAIL=
